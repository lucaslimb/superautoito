<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a1a"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="BATTLE"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/silver" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tv_title"
            android:layout_marginTop="15dp"
            android:weightSum="2">

            <TextView
                android:id="@+id/tv_player_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="JOGADOR"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/bronze"
                android:gravity="start"/>

            <TextView
                android:id="@+id/tv_opponent_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OPONENTE"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/bronze"
                android:gravity="end"/>
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:weightSum="2"
        android:baselineAligned="false"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/container_player_side"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:paddingEnd="4dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="130dp"
                android:layout_marginEnd="8dp">

                <include
                    android:id="@+id/player_card_6"
                    layout="@layout/item_character_card"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="20dp"/>

                <include
                    android:id="@+id/player_card_5"
                    layout="@layout/item_character_card"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="10dp"/>

                <include
                    android:id="@+id/player_card_4"
                    layout="@layout/item_character_card"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <include
                    android:id="@+id/player_card_3"
                    layout="@layout/item_character_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"/>

                <include
                    android:id="@+id/player_card_2"
                    layout="@layout/item_character_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"/>

                <include
                    android:id="@+id/player_card_1"
                    layout="@layout/item_character_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"/>
            </LinearLayout>

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#22ffffff"
            android:layout_marginHorizontal="4dp"/>

        <LinearLayout
            android:id="@+id/container_opponent_side"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical|start"
            android:paddingStart="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <include
                    android:id="@+id/enemy_card_1"
                    layout="@layout/item_character_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"/>

                <include
                    android:id="@+id/enemy_card_2"
                    layout="@layout/item_character_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"/>

                <include
                    android:id="@+id/enemy_card_3"
                    layout="@layout/item_character_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="130dp"
                android:layout_marginStart="8dp">

                <include
                    android:id="@+id/enemy_card_6"
                    layout="@layout/item_character_card"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="20dp"
                    android:layout_marginEnd="20dp"/>

                <include
                    android:id="@+id/enemy_card_5"
                    layout="@layout/item_character_card"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"/>

                <include
                    android:id="@+id/enemy_card_4"
                    layout="@layout/item_character_card"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_battle_log"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/card_border_normal"
        android:backgroundTint="#CC000000"
        android:padding="12dp"
        android:text="A batalha vai começar..."
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"/>

</LinearLayout>