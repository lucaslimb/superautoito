<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1a1a1a">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SUPER AUTO ITO"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/bronze"
        android:layout_marginBottom="16dp"
        android:fontFamily="sans-serif-black"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Junji Ito Cards Autobattle"
        android:textSize="16sp"
        android:textColor="#cccccc"
        android:layout_marginBottom="48dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#2a2a2a"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/edit_player_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Nome do jogador"
                android:textColorHint="#888888"
                android:textColor="@color/bronze"
                android:background="@drawable/edit_text_background"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textPersonName"
                android:maxLength="20"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CONFIRMAR"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/bronze"
                android:textColor="#cccccc"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.0 - Rede Local"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginTop="24dp"/>

</LinearLayout>
